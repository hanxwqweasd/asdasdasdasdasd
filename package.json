{
  "name": "eighth-floor-telegram-miniapp",
  "version": "4.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "backup": "sh scripts/backup.sh manual",
    "backup:verify": "sh scripts/verify-backup.sh",
    "backup:restore": "sh scripts/restore.sh",
    "export:data": "sh scripts/export-data.sh",
    "load:http": "node load-tests/http.mjs",
    "load:socket": "node load-tests/socket.mjs",
    "load:coop": "node load-tests/coop.mjs",
    "load:spectator": "node load-tests/spectator.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@sentry/node": "^10.65.0",
    "@socket.io/redis-streams-adapter": "^0.3.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "pg": "^8.16.0",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
