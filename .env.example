NODE_ENV=development
PORT=8080
PUBLIC_URL=http://localhost:8080

# Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eighth_floor
# Railway: ${{Redis.REDIS_URL}}
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED_IN_PRODUCTION=false

BOT_TOKEN=123456789:replace_me
BOT_USERNAME=replace_me_bot
WEBHOOK_SECRET=replace_with_a_long_random_string_at_least_16_chars
AUTH_MAX_AGE_SECONDS=86400
ALLOW_DEV_AUTH=true
DEV_USER_ID=10001

# Первый superadmin создаётся только когда таблица admins пуста.
ADMIN_USERNAME=owner
ADMIN_PASSWORD=replace_with_a_password_of_at_least_12_characters
ADMIN_SESSION_SECRET=replace_with_a_separate_random_string_of_at_least_32_chars
ADMIN_SESSION_HOURS=24

BROADCAST_BATCH_SIZE=15
RATE_LIMIT_MAX=180
IDEMPOTENCY_TTL_SECONDS=21600
PRESENCE_TTL_SECONDS=90
COOP_MATCH_TTL_SECONDS=7200
COOP_TURN_SECONDS=75
COOP_ELEVATOR_SECONDS=720
BUILDING_CAPACITY=30
MARKET_COMMISSION_PERCENT=5

# Backup. На Railway подключите Volume в /backups.
BACKUP_ENABLED=false
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=14
BACKUP_HOUR_UTC=2
PRE_MIGRATION_BACKUP=false
PRE_MIGRATION_BACKUP_REQUIRED=false
# Необязательный HTTP PUT endpoint внешнего хранилища.
BACKUP_WEBHOOK_URL=

# Наблюдаемость.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ENABLE_METRICS=true
METRICS_TOKEN=
APP_VERSION=4.1.0
SUPPORT_SCREENSHOT_MAX_BYTES=1500000
